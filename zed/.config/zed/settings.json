// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "git": {
    "enable_status": true,
    "disable_git": false,
  },
  "terminal": {
    "dock": "right",
    "font_family": "BlexMono Nerd Font Mono",
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh", // or path to your preferred shell
        "args": ["-c", "tmux new-session -A -s \"$(basename \"$PWD\")\""],
      },
    },
  },
  "theme": "Catppuccin Mocha",
  "auto_install_extensions": {
    "dockerfile": true,
    "html": true,
  },
  "languages": {
    "Python": {
      "language_servers": [
        // Enable ty, disable basedpyright, and enable all
        // other registered language servers (ruff, pylsp, pyright).
        "ty",
        "!basedpyright",
        "...",
      ],
    },
  },
  "feature_flags": {
    "tabular-data-preview": "on",
    "notebooks": "on",
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
}
